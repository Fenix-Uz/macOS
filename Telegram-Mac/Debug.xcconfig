// Configuration settings file format documentation can be found at:
// https://help.apple.com/xcode/#/dev745c5c974


#include "common.xcconfig"

DSA_PEM_FILE = dsa_pub.pem
// Sparkle disabled — points at a dead localhost URL so Sparkle tries to
// fetch, fails the network call, and silently reports "no update". Empty
// string crashes AppUpdateViewController.swift:570 (force-unwrapped cast).
SFEED_URL = https:$(SIMPLE_SLASH)/127.0.0.1/none.xml
SOURCE = DEBUG

TYPE = -D'BETA'
OTHER_SWIFT_FLAGS = $(TYPE)

// Xcode 16 "Debug Dylib" (splits the app into a thin exec + Fenixuz.debug.dylib) fails to load
// here — "library load denied by system policy" — because the debug dylib's signature doesn't
// satisfy this fork's hardened-runtime / library-validation signing, so dyld aborts (SIGABRT)
// on launch. Disabling it builds the app as a single binary (normal debugging still works).
ENABLE_DEBUG_DYLIB = NO
