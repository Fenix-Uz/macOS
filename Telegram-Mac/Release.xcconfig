#include "common.xcconfig"
DSA_PEM_FILE = dsa_pub_prod.pem
// Sparkle disabled (Fenixuz fork) — same posture as Debug.xcconfig.
// Original upstream URL was https://mac-updates.telegram.org/updates/versions.xml
// which would download and install the official Telegram client, silently
// erasing this fork. Mac App Store handles updates, Sparkle not needed.
SFEED_URL = https:$(SIMPLE_SLASH)/127.0.0.1/none.xml
SOURCE = APP_STORE

TYPE = -D'APP_STORE'
OTHER_SWIFT_FLAGS = $(TYPE)
